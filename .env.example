# ─────────────────────────────────────────────────────────────
# SupportForge — Environment Variables
# Copy to .env and fill in required values
# NEVER commit .env to version control
# ─────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────
POSTGRES_USER=supportforge
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=supportforge

# ── Redis ─────────────────────────────────────────────────────
# No auth needed for local Docker; set password for production
REDIS_URL=redis://redis:6379/0

# ── Security ──────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_generate_with_python_secrets_token_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── LLM Providers ─────────────────────────────────────────────
# Primary: Groq (free tier) — get key at https://console.groq.com
GROQ_API_KEY=Your_Groq_API_Key
GROQ_MODEL=llama-3.1-8b-instant

# Fallback: Ollama (local, optional)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1

# ── LangSmith (Optional — graceful degradation if not set) ────
# Get free key at https://smith.langchain.com
LANGSMITH_API_KEY=Your_LangSmith_API_Key
LANGSMITH_PROJECT=supportforge
LANGCHAIN_TRACING_V2=true

# ── Frontend ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ── Observability ─────────────────────────────────────────────
GRAFANA_PASSWORD=admin_change_me
ENVIRONMENT=development   # development | production

# ── Execution Budget (Invariants — do not lower these) ────────
MAX_STEPS_PER_TICKET=10
MAX_LATENCY_SECONDS=10
MAX_KB_RETRIES=3
MAX_LLM_CALLS_PER_TICKET=5
MAX_TOKENS_PER_TICKET=5000

# ── Concurrency ───────────────────────────────────────────────
MAX_CONCURRENT_AGENT_EXECUTIONS=20
MAX_TICKETS_PER_USER_PER_MINUTE=5

# ── RAG ───────────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
EMBEDDING_CACHE_TTL_SECONDS=86400   # 24 hours

# ── Replay Retention ──────────────────────────────────────────
REPLAY_FULL_RETENTION_DAYS=7
REPLAY_SUMMARY_RETENTION_DAYS=90
